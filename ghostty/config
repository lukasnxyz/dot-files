font-family = Iosevka Term
font-size = 14
font-feature = -calt
font-feature = -liga
font-feature = -dlig
#theme = dark: "Gruber Darker", light: "Gruvbox Light"
theme = dark:"Gruber Darker", light:"Adwaita"

app-notifications = no-clipboard-copy
confirm-close-surface = false
gtk-single-instance = true

window-padding-x = 4
window-padding-y = 4
window-vsync = true
window-inherit-font-size = true
gtk-titlebar = false
#window-decoration = none
